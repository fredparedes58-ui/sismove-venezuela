# ─── SismoVE · variables de entorno ────────────────────────────────────────
# Copia a .env (local) y configúralas en Vercel → Settings → Environment Variables.
# NUNCA subir .env al repo.

# Nuestro Supabase (el que alimenta dashboard + bot)
SUPABASE_URL=https://TU-PROYECTO.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...          # service role — SOLO server/edge, bypasea RLS
SUPABASE_ANON_KEY=eyJ...                   # anon — lo usa el dashboard (solo lectura)

# Scraper → Webhook (HMAC-SHA256, patrón Krujens)
SCRAPER_WEBHOOK_URL=https://TU-APP.vercel.app/api/webhooks/scraper
SCRAPER_WEBHOOK_SECRET=                     # openssl rand -hex 32

# Torres de telefonía reales (capa de cobertura) — token gratis en opencellid.org
OPENCELLID_API_KEY=                          # MCC Venezuela = 734

# Bot de Telegram (patrón VITAS Coach Copilot)
TELEGRAM_BOT_TOKEN=                         # BotFather
TELEGRAM_WEBHOOK_SECRET=                    # openssl rand -hex 32  (header secret_token)
ANTHROPIC_API_KEY=                          # para el agente (tool use)
ANTHROPIC_MODEL=claude-haiku-4-5-20251001   # rápido y barato para tool use
